   "source": [
    "## 3. Data Loading with Dataset Factory"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Dataset configuration\n",
    "DATASET = 'cifar10'  # or 'cifar100'\n",
    "DATA_ROOT = './data'\n",
    "BATCH_SIZE = 64\n",
    "NUM_WORKERS = 4\n",
    "\n",
    "# Get dataset info\n",
    "from darts_cnn.data import get_dataset_info, get_num_classes\n",
    "\n",
    "dataset_info = get_dataset_info(DATASET)\n",
    "num_classes = get_num_classes(DATASET)\n",
    "\n",
    "print(f\"Dataset: {dataset_info.name}\")\n",
    "print(f\"Number of classes: {dataset_info.num_classes}\")\n",
    "print(f\"Input size: {dataset_info.input_size}\")\n",
    "print(f\"Mean: {dataset_info.mean}\")\n",
    "print(f\"Std: {dataset_info.std}\")\n",
    "if dataset_info.class_names:\n",
    "    print(f\"Classes: {dataset_info.class_names[:5]}...\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create data loaders using dataset factory\n",
    "train_loader, valid_loader, test_loader = create_dataloaders(\n",
    "    DATASET,\n",
    "    data_root=DATA_ROOT,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    num_workers=NUM_WORKERS,\n",
    "    train_portion=0.5,  # 50% for training, 50% for validation during search\n",
    "    cutout=True,\n",
    "    cutout_length=16\n",
    ")\n",
    "\n",
    "print(f\"Train batches: {len(train_loader)}\")\n",
    "print(f\"Valid batches: {len(valid_loader)}\")\n",
    "print(f\"Test batches: {len(test_loader)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize sample images\n",
    "def imshow(img, mean, std):\n",
    "    \"\"\"Denormalize and display image\"\"\"\n",
    "    img = img.clone()\n",
    "    for i in range(3):\n",
    "        img[i] = img[i] * std[i] + mean[i]\n",
