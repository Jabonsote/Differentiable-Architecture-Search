    "for i, ax in enumerate(axes.flat):\n",
    "    img = imshow(images[i], mean, std)\n",
    "    img = torch.clamp(img, 0, 1)\n",
    "    ax.imshow(img.permute(1, 2, 0))\n",
    "    ax.set_title(f\"Label: {CIFAR10_INFO.class_names[labels[i]]}\")\n",
    "    ax.axis('off')\n",
    "\n",
    "plt.suptitle(\"Sample CIFAR-10 Images with Cutout Augmentation\", fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Phase 1: Architecture Search"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Search configuration\n",
    "SEARCH_CONFIG = {\n",
    "    'init_channels': 16,\n",
    "    'layers': 8,\n",
    "    'steps': 4,\n",
    "    'multiplier': 4,\n",
    "    'epochs': 50,\n",
    "    'batch_size': BATCH_SIZE,\n",
    "    'learning_rate': 0.025,\n",
    "    'learning_rate_min': 0.001,\n",
    "    'momentum': 0.9,\n",
    "    'weight_decay': 3e-4,\n",
    "    'grad_clip': 5.0,\n",
    "    'arch_learning_rate': 3e-4,\n",
    "    'arch_weight_decay': 1e-3,\n",
    "    'unrolled': False,\n",
    "    'train_portion': 0.5,\n",
    "}\n",
    "\n",
    "print(\"Search Configuration:\")\n",
    "for k, v in SEARCH_CONFIG.items():\n",
    "    print(f\"  {k}: {v}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create search model\n",
    "criterion = nn.CrossEntropyLoss()\n",
    "model = Network(\n",
    "    C=SEARCH_CONFIG['init_channels'],\n",
    "    num_classes=num_classes,\n",
    "    layers=SEARCH_CONFIG['layers'],\n",
    "    criterion=criterion\n",
    ").to(device)\n",
    "\n",
    "print(f\"Search model parameters: {count_parameters(model):.2f}M\")\n",
    "print(f\"Alpha parameters: {model.alphas_normal.numel() + model.alphas_reduce.numel()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create optimizer and scheduler\n",
    "optimizer = optim.SGD(\n",
    "    model.parameters(),\n",
    "    lr=SEARCH_CONFIG['learning_rate'],\n",
    "    momentum=SEARCH_CONFIG['momentum'],\n",
    "    weight_decay=SEARCH_CONFIG['weight_decay']\n",
    ")\n",
    "\n",
    "scheduler = optim.lr_scheduler.CosineAnnealingLR(\n",
    "    optimizer, \n",
    "    T_max=SEARCH_CONFIG['epochs'],\n",
    "    eta_min=SEARCH_CONFIG['learning_rate_min']\n",
    ")\n",
    "\n",
    "# Create architect\n",
    "architect_args = {\n",
    "    'momentum': SEARCH_CONFIG['momentum'],\n",
    "    'weight_decay': SEARCH_CONFIG['weight_decay'],\n",
    "    'arch_learning_rate': SEARCH_CONFIG['arch_learning_rate'],\n",
    "    'arch_weight_decay': SEARCH_CONFIG['arch_weight_decay']\n",
    "}\n",
    "architect = Architect(model, architect_args)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Training functions\n",
    "def train_step(train_queue, valid_queue, model, architect, criterion, optimizer, lr, args):\n",
    "    \"\"\"One training step\"\"\"\n",
    "    model.train()\n",
    "    objs = AverageMeter()\n",
    "    top1 = AverageMeter()\n",
    "    \n",
    "    train_iter = iter(train_queue)\n",
    "    valid_iter = iter(valid_queue)\n",
    "    \n",
    "    for step in range(len(train_queue)):\n",
    "        # Get batch\n",
    "        try:\n",
    "            input, target = next(train_iter)\n",
    "        except StopIteration:\n",
    "            train_iter = iter(train_queue)\n",
    "            input, target = next(train_iter)\n",
    "        \n",
    "        try:\n",
    "            input_search, target_search = next(valid_iter)\n",
    "        except StopIteration:\n",
    "            valid_iter = iter(valid_queue)\n",
    "            input_search, target_search = next(valid_iter)\n",
    "        \n",
    "        input = input.to(device)\n",
    "        target = target.to(device)\n",
    "        input_search = input_search.to(device)\n",
    "        target_search = target_search.to(device)\n",
    "        \n",
    "        # Architecture step\n",
    "        architect.step(input, target, input_search, target_search, \n",
    "                      lr, optimizer, unrolled=args.get('unrolled', False))\n",
    "        \n",
    "        # Weight step\n",
    "        optimizer.zero_grad()\n",
    "        logits = model(input)\n",
    "        loss = criterion(logits, target)\n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), args.get('grad_clip', 5.0))\n",
    "        optimizer.step()\n",
    "        \n",
    "        # Metrics\n",
    "        prec1, _ = accuracy(logits, target, topk=(1,))\n",
    "        n = input.size(0)\n",
    "        objs.update(loss.item(), n)\n",
    "        top1.update(prec1, n)\n",
    "    \n",
    "    return objs.avg, top1.avg\n",
    "\n",
    "def infer_step(data_queue, model, criterion):\n",
    "    \"\"\"Inference step\"\"\"\n",
    "    model.eval()\n",
    "    objs = AverageMeter()\n",
    "    top1 = AverageMeter()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for input, target in data_queue:\n",
    "            input = input.to(device)\n",
    "            target = target.to(device)\n",
    "            \n",
    "            logits = model(input)\n",
    "            loss = criterion(logits, target)\n",
    "            \n",
    "            prec1, _ = accuracy(logits, target, topk=(1,))\n",
    "            n = input.size(0)\n",
    "            objs.update(loss.item(), n)\n",
    "            top1.update(prec1, n)\n",
    "    \n",
    "    return objs.avg, top1.avg"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run architecture search\n",
    "print(\"Starting Architecture Search...\")\n",
    "search_start_time = time.time()\n",
    "\n",
    "best_acc = 0.0\n",
    "best_genotype = None\n",
    "metrics = MetricsTracker()\n",
    "\n",
    "for epoch in range(SEARCH_CONFIG['epochs']):\n",
    "    scheduler.step()\n",
    "    lr = scheduler.get_last_lr()[0]\n",
    "    \n",
    "    train_loss, train_acc = train_step(\n",
    "        train_loader, valid_loader, model, architect,\n",
    "        criterion, optimizer, lr, SEARCH_CONFIG\n",
    "    )\n",
    "    \n",
    "    valid_loss, valid_acc = infer_step(valid_loader, model, criterion)\n",
    "    \n",
    "    metrics.update(\n",
    "        train_loss=train_loss,\n",
    "        train_acc1=train_acc,\n",
    "        valid_loss=valid_loss,\n",
    "        valid_acc1=valid_acc,\n",
    "        lr=lr\n",
    "    )\n",
    "    \n",
    "    # Get current genotype\n",
    "    genotype = model.genotype()\n",
    "    \n",
    "    if valid_acc > best_acc:\n",
    "        best_acc = valid_acc\n",
    "        best_genotype = genotype\n",
    "    \n",
    "    if epoch % 10 == 0:\n",
    "        print(f\"Epoch {epoch:3d}: lr={lr:.6f}, train_loss={train_loss:.4f}, \"\n",
    "              f\"train_acc={train_acc:.2f}%, valid_acc={valid_acc:.2f}%\")\n",
    "\n",
    "search_time = time.time() - search_start_time\n",
    "print(f\"\\nSearch completed in {search_time/60:.2f} minutes\")\n",
    "print(f\"Best validation accuracy: {best_acc:.2f}%\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize training curves\n",
    "history = metrics.history\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "epochs = range(len(history['train_loss']))\n",
    "\n",
    "axes[0].plot(epochs, history['train_loss'], label='Train')\n",
    "axes[0].plot(epochs, history['valid_loss'], label='Valid')\n",
    "axes[0].set_xlabel('Epoch')\n",
    "axes[0].set_ylabel('Loss')\n",
    "axes[0].set_title('Training and Validation Loss')\n",
    "axes[0].legend()\n",
    "axes[0].grid(True)\n",
    "\n",
    "axes[1].plot(epochs, history['train_acc1'], label='Train')\n",
    "axes[1].plot(epochs, history['valid_acc1'], label='Valid')\n",
    "axes[1].set_xlabel('Epoch')\n",
    "axes[1].set_ylabel('Accuracy (%)')\n",
    "axes[1].set_title('Training and Validation Accuracy')\n",
    "axes[1].legend()\n",
    "axes[1].grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize alpha weights evolution\n",
    "alpha_weights = model.get_alpha_weights()\n",
    "print(\"Alpha weights shape:\", alpha_weights['normal'].shape)\n",
    "print(\"\\nOperations available:\", PRIMITIVES)"
   ]
  },
