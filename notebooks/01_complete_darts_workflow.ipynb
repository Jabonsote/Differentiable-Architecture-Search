  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Phase 3: Evaluation (Retraining)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Evaluation configuration (full training)\n",
    "EVAL_CONFIG = {\n",
    "    'init_channels': 36,\n",
    "    'layers': 20,\n",
    "    'epochs': 100,  # Reduced for demo; normally 600\n",
    "    'batch_size': 96,\n",
    "    'learning_rate': 0.025,\n",
    "    'momentum': 0.9,\n",
    "    'weight_decay': 3e-4,\n",
    "    'grad_clip': 5.0,\n",
    "    'auxiliary': True,\n",
    "    'auxiliary_weight': 0.4,\n",
    "    'drop_path_prob': 0.2,\n",
    "}\n",
    "\n",
    "print(\"Evaluation Configuration:\")\n",
    "for k, v in EVAL_CONFIG.items():\n",
    "    print(f\"  {k}: {v}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create evaluation model\n",
    "eval_model = create_network(\n",
    "    C=EVAL_CONFIG['init_channels'],\n",
    "    num_classes=num_classes,\n",
    "    layers=EVAL_CONFIG['layers'],\n",
    "    auxiliary=EVAL_CONFIG['auxiliary'],\n",
    "    genotype=best_genotype,\n",
    "    dataset=DATASET\n",
    ").to(device)\n",
    "\n",
    "print(f\"Evaluation model parameters: {count_parameters(eval_model):.2f}M\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create optimizer and scheduler\n",
    "eval_optimizer = optim.SGD(\n",
    "    eval_model.parameters(),\n",
    "    lr=EVAL_CONFIG['learning_rate'],\n",
    "    momentum=EVAL_CONFIG['momentum'],\n",
    "    weight_decay=EVAL_CONFIG['weight_decay']\n",
    ")\n",
    "\n",
    "eval_scheduler = optim.lr_scheduler.CosineAnnealingLR(\n",
    "    eval_optimizer, T_max=EVAL_CONFIG['epochs']\n",
    ")\n",
    "\n",
    "# Create new data loaders for evaluation (full training set)\n",
    "_, eval_valid_loader, eval_test_loader = create_dataloaders(\n",
    "    DATASET,\n",
    "    data_root=DATA_ROOT,\n",
    "    batch_size=EVAL_CONFIG['batch_size'],\n",
    "    num_workers=NUM_WORKERS,\n",
    "    train_portion=0.9,\n",
    ")\n",
    "\n",
    "print(f\"Eval train batches: {len(train_loader)}\")\n",
    "print(f\"Eval valid batches: {len(eval_valid_loader)}\")\n",
    "print(f\"Eval test batches: {len(eval_test_loader)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Evaluation training loop\n",
    "def eval_train_step(model, train_queue, criterion, optimizer, args):\n",
    "    model.train()\n",
    "    objs = AverageMeter()\n",
    "    top1 = AverageMeter()\n",
    "    \n",
    "    for input, target in train_queue:\n",
    "        input = input.to(device)\n",
    "        target = target.to(device)\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        \n",
    "        logits, logits_aux = model(input)\n",
    "        \n",
    "        loss = criterion(logits, target)\n",
    "        if args.get('auxiliary', False) and logits_aux is not None:\n",
    "            loss_aux = criterion(logits_aux, target)\n",
    "            loss += args.get('auxiliary_weight', 0.4) * loss_aux\n",
    "        \n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), args.get('grad_clip', 5.0))\n",
    "        optimizer.step()\n",
    "        \n",
    "        prec1, _ = accuracy(logits, target, topk=(1,))\n",
    "        n = input.size(0)\n",
    "        objs.update(loss.item(), n)\n",
    "        top1.update(prec1, n)\n",
    "    \n",
    "    return objs.avg, top1.avg\n",
    "\n",
    "def eval_infer_step(model, data_queue, criterion):\n",
    "    model.eval()\n",
    "    objs = AverageMeter()\n",
    "    top1 = AverageMeter()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for input, target in data_queue:\n",
    "            input = input.to(device)\n",
    "            target = target.to(device)\n",
    "            \n",
    "            logits, _ = model(input)\n",
    "            loss = criterion(logits, target)\n",
    "            \n",
    "            prec1, _ = accuracy(logits, target, topk=(1,))\n",
    "            n = input.size(0)\n",
    "            objs.update(loss.item(), n)\n",
    "            top1.update(prec1, n)\n",
    "    \n",
    "    return objs.avg, top1.avg"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run evaluation training\n",
    "print(\"Starting Evaluation Training...\")\n",
    "eval_start_time = time.time()\n",
    "\n",
    "best_valid_acc = 0.0\n",
    "eval_metrics = {'train_loss': [], 'train_acc': [], 'valid_loss': [], 'valid_acc': []}\n",
    "\n",
    "for epoch in range(EVAL_CONFIG['epochs']):\n",
    "    eval_scheduler.step()\n",
    "    \n",
    "    # Update drop path probability\n",
    "    eval_model.drop_path_prob = EVAL_CONFIG['drop_path_prob'] * epoch / EVAL_CONFIG['epochs']\n",
    "    \n",
    "    train_loss, train_acc = eval_train_step(\n",
    "        eval_model, train_loader, criterion, eval_optimizer, EVAL_CONFIG\n",
    "    )\n",
    "    \n",
    "    valid_loss, valid_acc = eval_infer_step(eval_model, eval_valid_loader, criterion)\n",
    "    \n",
    "    eval_metrics['train_loss'].append(train_loss)\n",
    "    eval_metrics['train_acc'].append(train_acc)\n",
    "    eval_metrics['valid_loss'].append(valid_loss)\n",
    "    eval_metrics['valid_acc'].append(valid_acc)\n",
    "    \n",
    "    if valid_acc > best_valid_acc:\n",
    "        best_valid_acc = valid_acc\n",
    "        best_model_state = {k: v.cpu().clone() for k, v in eval_model.state_dict().items()}\n",
    "    \n",
    "    if epoch % 20 == 0:\n",
    "        print(f\"Epoch {epoch:3d}: train_acc={train_acc:.2f}%, valid_acc={valid_acc:.2f}%\")\n",
    "\n",
    "eval_time = time.time() - eval_start_time\n",
    "print(f\"\\nEvaluation completed in {eval_time/60:.2f} minutes\")\n",
    "print(f\"Best validation accuracy: {best_valid_acc:.2f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Phase 4: Test Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load best model and evaluate on test set\n",
    "eval_model.load_state_dict(best_model_state)\n",
    "eval_model.to(device)\n",
    "\n",
    "test_loss, test_acc = eval_infer_step(eval_model, eval_test_loader, criterion)\n",
    "\n",
    "print(f\"Test Accuracy: {test_acc:.2f}%\")\n",
    "print(f\"Test Loss: {test_loss:.4f}\")"
   ]
