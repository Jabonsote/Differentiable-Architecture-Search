    "\n",
    "mean = torch.tensor(CIFAR10_INFO.mean)\n",
    "std = torch.tensor(CIFAR10_INFO.std)\n",
    "\n",
    "# Get a batch\n",
    "images, labels = next(iter(train_loader))\n",
